# Server
PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password123
DB_NAME=legaltech_db
DB_SSLMODE=disable

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRY_HOURS=1
JWT_REFRESH_EXPIRY_DAYS=30

# SMTP (used for forgot-password emails). Leave blank to disable email sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@legaltech.ai

# AI Assistant (Anthropic Claude API) - required for AI chat, draft generation, and research
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# TURN relay for the Video Conference feature's peer-to-peer WebRTC media
# (optional). STUN (stun:stun.l.google.com:19302) is always used and is
# enough for most networks; configure TURN only if meetings fail to connect
# behind symmetric NAT/restrictive firewalls. Leave blank to run STUN-only.
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=
